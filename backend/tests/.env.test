# 测试环境配置
# 注意：这是示例配置，实际使用时请根据环境调整

# ============ 基础配置 ============
TEST_BASE_URL=http://115.190.75.88:8000
TEST_API_PREFIX=/api/v1

# ============ 超时设置 ============
TEST_REQUEST_TIMEOUT=30
TEST_LLM_REQUEST_TIMEOUT=60

# ============ 并发设置 ============
TEST_MAX_CONCURRENT=10

# ============ 管理员账号 ============
# 如果有管理员账号，请填写
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123

# ============ 测试控制 ============
# 是否在测试后清理数据
TEST_CLEANUP_AFTER_TEST=true

# 是否跳过性能测试
TEST_SKIP_PERFORMANCE=false

# 是否跳过安全测试
TEST_SKIP_SECURITY=false

# ============ 日志配置 ============
TEST_LOG_LEVEL=INFO

# ============ 测试数据配置 ============
# 测试租户前缀（用于标识测试数据）
TEST_TENANT_PREFIX=auto_test_

# ============ 性能测试配置 ============
# 并发用户数
TEST_CONCURRENT_USERS=10

# 性能测试持续时间（秒）
TEST_PERFORMANCE_DURATION=30

# ============ LLM 配置 ============
# 使用的LLM提供商（zhipuai/openai/anthropic）
TEST_LLM_PROVIDER=zhipuai

# 智谱AI配置（如果使用）
TEST_ZHIPUAI_API_KEY=your_zhipuai_api_key_here
TEST_ZHIPUAI_MODEL=glm-4-flash

# OpenAI配置（如果使用）
TEST_OPENAI_API_KEY=your_openai_api_key_here
TEST_OPENAI_MODEL=gpt-3.5-turbo
TEST_OPENAI_BASE_URL=https://api.openai.com/v1
